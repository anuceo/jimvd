{
  "workload_name": "high_write",
  "description": "High-write stress test: 40% writes against a 1000-object employee table; validates UAF stability and measures per-delta propagation fanout",
  "tables": {
    "employees": {
      "attributes": {
        "Role":       ["Admin", "Engineer", "Manager", "Viewer"],
        "Region":     ["US", "EU", "APAC"],
        "Department": ["Engineering", "Sales", "HR", "Finance"]
      },
      "initial_objects": 1000,
      "correlation_hint": "high"
    }
  },
  "query_mix": [
    {"type": "eq",  "weight": 30, "table": "employees", "attribute": "Role",
     "values": ["Admin", "Engineer", "Manager", "Viewer"]},
    {"type": "and", "weight": 20, "table": "employees", "attributes": ["Role", "Region"]},
    {"type": "and", "weight": 10, "table": "employees", "attributes": ["Role", "Region", "Department"]}
  ],
  "write_mix": {
    "insert_rate": 0.20,
    "update_rate": 0.15,
    "delete_rate": 0.05,
    "attributes": ["Role", "Region", "Department"],
    "table": "employees"
  },
  "run_options": {
    "total_operations": 50000,
    "metrics_interval_ops": 5000,
    "warmup_ops": 5000,
    "adaptation_enabled": true
  }
}
