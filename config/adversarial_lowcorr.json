{
  "workload_name": "adversarial_lowcorr",
  "description": "Adversarial shift with low-correlation data (few shared attribute combinations)",
  "transition_at_ops": 5000,
  "phase_a": {
    "workload_name": "iam_lowcorr",
    "description": "Role/Region/Department with low correlation hint",
    "adaptation": {
      "materialization_threshold": 3,
      "eviction_ticks": 500
    },
    "tables": {
      "employees": {
        "attributes": {
          "Role":       ["Admin", "Engineer", "Manager", "Viewer"],
          "Region":     ["US", "EU", "APAC"],
          "Department": ["Engineering", "Sales", "HR", "Finance"]
        },
        "initial_objects": 1000,
        "correlation_hint": "low"
      }
    },
    "query_mix": [
      { "type": "eq",  "weight": 40, "attribute": "Role",   "values": ["Admin", "Engineer", "Manager", "Viewer"] },
      { "type": "and", "weight": 30, "attributes": ["Role", "Region"] },
      { "type": "and", "weight": 20, "attributes": ["Role", "Region", "Department"] },
      { "type": "or",  "weight": 10, "attributes": ["Role"], "values": ["Admin", "Engineer"] }
    ],
    "write_mix": {
      "insert_rate": 0.1,
      "update_rate": 0.05,
      "delete_rate": 0.02,
      "attributes": ["Role", "Region", "Department"]
    },
    "run_options": {
      "total_operations": 5000,
      "metrics_interval_ops": 500,
      "warmup_ops": 500,
      "adaptation_enabled": true
    }
  },
  "phase_b": {
    "workload_name": "clearance_lowcorr",
    "description": "Clearance/Project/Office with low correlation hint",
    "adaptation": {
      "materialization_threshold": 3,
      "eviction_ticks": 500
    },
    "tables": {
      "employees": {
        "attributes": {
          "Clearance": ["Public", "Confidential", "Secret", "TopSecret"],
          "Project":   ["Alpha", "Beta", "Gamma", "Delta"],
          "Office":    ["HQ", "Branch1", "Branch2", "Remote"]
        },
        "initial_objects": 0,
        "correlation_hint": "low"
      }
    },
    "query_mix": [
      { "type": "eq",  "weight": 40, "attribute": "Clearance", "values": ["Public", "Confidential", "Secret", "TopSecret"] },
      { "type": "and", "weight": 30, "attributes": ["Clearance", "Project"] },
      { "type": "and", "weight": 20, "attributes": ["Clearance", "Project", "Office"] },
      { "type": "or",  "weight": 10, "attributes": ["Clearance"], "values": ["Secret", "TopSecret"] }
    ],
    "write_mix": {
      "insert_rate": 0.1,
      "update_rate": 0.05,
      "delete_rate": 0.02,
      "attributes": ["Clearance", "Project", "Office"]
    },
    "run_options": {
      "total_operations": 5000,
      "metrics_interval_ops": 500,
      "warmup_ops": 0,
      "adaptation_enabled": true
    }
  }
}
