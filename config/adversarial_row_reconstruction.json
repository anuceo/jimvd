{
  "workload_name": "adversarial_row_reconstruction",
  "description": "Forces row reconstruction by including a non-factorised Salary attribute",
  "transition_at_ops": 5000,
  "phase_a": {
    "workload_name": "iam_phase_with_salary",
    "description": "Role/Region/Department factorised; Salary forces row reconstruction",
    "adaptation": {
      "materialization_threshold": 3,
      "eviction_ticks": 500
    },
    "tables": {
      "employees": {
        "attributes": {
          "Role":       ["Admin", "Engineer", "Manager", "Viewer"],
          "Region":     ["US", "EU", "APAC"],
          "Department": ["Engineering", "Sales", "HR", "Finance"],
          "Salary":     null
        },
        "factorize_attributes": ["Role", "Region", "Department"],
        "initial_objects": 1000,
        "correlation_hint": "high"
      }
    },
    "query_mix": [
      { "type": "eq",  "weight": 40, "attribute": "Role",   "values": ["Admin", "Engineer", "Manager", "Viewer"] },
      { "type": "and", "weight": 30, "attributes": ["Role", "Region"] },
      { "type": "and", "weight": 10, "attributes": ["Role", "Region", "Department"] },
      { "type": "eq",  "weight": 10, "attribute": "Salary", "values": [] },
      { "type": "and", "weight": 10, "attributes": ["Role", "Salary"] }
    ],
    "write_mix": {
      "insert_rate": 0.1,
      "update_rate": 0.05,
      "delete_rate": 0.02,
      "attributes": ["Role", "Region", "Department", "Salary"]
    },
    "run_options": {
      "total_operations": 5000,
      "metrics_interval_ops": 500,
      "warmup_ops": 500,
      "adaptation_enabled": true
    }
  },
  "phase_b": {
    "workload_name": "clearance_phase_with_salary",
    "description": "Clearance/Project/Office factorised; Salary still forces row reconstruction",
    "adaptation": {
      "materialization_threshold": 3,
      "eviction_ticks": 500
    },
    "tables": {
      "employees": {
        "attributes": {
          "Clearance": ["Public", "Confidential", "Secret", "TopSecret"],
          "Project":   ["Alpha", "Beta", "Gamma", "Delta"],
          "Office":    ["HQ", "Branch1", "Branch2", "Remote"],
          "Salary":    null
        },
        "factorize_attributes": ["Clearance", "Project", "Office"],
        "initial_objects": 0,
        "correlation_hint": "high"
      }
    },
    "query_mix": [
      { "type": "eq",  "weight": 40, "attribute": "Clearance", "values": ["Public", "Confidential", "Secret", "TopSecret"] },
      { "type": "and", "weight": 30, "attributes": ["Clearance", "Project"] },
      { "type": "and", "weight": 10, "attributes": ["Clearance", "Project", "Office"] },
      { "type": "eq",  "weight": 10, "attribute": "Salary",    "values": [] },
      { "type": "and", "weight": 10, "attributes": ["Clearance", "Salary"] }
    ],
    "write_mix": {
      "insert_rate": 0.1,
      "update_rate": 0.05,
      "delete_rate": 0.02,
      "attributes": ["Clearance", "Project", "Office", "Salary"]
    },
    "run_options": {
      "total_operations": 5000,
      "metrics_interval_ops": 500,
      "warmup_ops": 0,
      "adaptation_enabled": true
    }
  }
}
