{
  "workload_name": "join_workload",
  "description": "Two-table join workload: employees ⋈ departments; mix of filtered and unfiltered joins",
  "adaptation": {
    "materialization_threshold": 3,
    "eviction_ticks": 500
  },
  "tables": {
    "employees": {
      "attributes": {
        "Role":       ["Admin", "Engineer", "Manager", "Viewer"],
        "Region":     ["US", "EU", "APAC"],
        "Department": ["Engineering", "Sales", "HR", "Finance"]
      },
      "initial_objects": 500,
      "correlation_hint": "high"
    },
    "departments": {
      "attributes": {
        "Department": ["Engineering", "Sales", "HR", "Finance"],
        "Manager":    ["Alice", "Bob", "Carol", "Dave"]
      },
      "initial_objects": 4,
      "correlation_hint": "high"
    }
  },
  "query_mix": [
    {
      "type": "eq", "weight": 30,
      "table": "employees",
      "attribute": "Role",
      "values": ["Admin", "Engineer", "Manager", "Viewer"]
    },
    {
      "type": "join", "weight": 30,
      "left_table": "employees",
      "right_table": "departments",
      "join_attribute": "Department",
      "left_filters": [],
      "right_filters": []
    },
    {
      "type": "join", "weight": 20,
      "left_table": "employees",
      "right_table": "departments",
      "join_attribute": "Department",
      "left_filters": [
        { "type": "eq", "attribute": "Role", "values": ["Admin"] }
      ],
      "right_filters": []
    },
    {
      "type": "and", "weight": 20,
      "table": "employees",
      "attributes": ["Role", "Region"]
    }
  ],
  "write_mix": {
    "insert_rate": 0.05,
    "update_rate": 0.03,
    "delete_rate": 0.02,
    "attributes": ["Role", "Region", "Department"],
    "table": "employees"
  },
  "run_options": {
    "total_operations": 3000,
    "metrics_interval_ops": 500,
    "warmup_ops": 500,
    "adaptation_enabled": true
  }
}
