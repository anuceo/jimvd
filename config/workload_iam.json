{
  "workload_name": "iam_small",
  "description": "Small IAM workload with correlated Role, Region, Department",
  "tables": {
    "employees": {
      "attributes": {
        "Role": ["Admin", "Engineer", "Manager", "Viewer"],
        "Region": ["US", "EU", "APAC"],
        "Department": ["Engineering", "Sales", "HR", "Finance"]
      },
      "initial_objects": 1000,
      "correlation_hint": "high"
    }
  },
  "query_mix": [
    {
      "type": "eq",
      "weight": 40,
      "attribute": "Role",
      "values": ["Admin", "Engineer", "Manager", "Viewer"]
    },
    {
      "type": "and",
      "weight": 30,
      "attributes": ["Role", "Region"]
    },
    {
      "type": "and",
      "weight": 20,
      "attributes": ["Role", "Region", "Department"]
    },
    {
      "type": "or",
      "weight": 10,
      "attributes": ["Role"],
      "values": ["Admin", "Engineer"]
    }
  ],
  "write_mix": {
    "insert_rate": 0.1,
    "update_rate": 0.05,
    "delete_rate": 0.02,
    "attributes": ["Role", "Region", "Department"]
  },
  "run_options": {
    "total_operations": 10000,
    "metrics_interval_ops": 500,
    "warmup_ops": 500,
    "adaptation_enabled": true
  }
}
